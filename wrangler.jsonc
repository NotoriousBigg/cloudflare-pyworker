{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "cloudflare-pyworker",
	"main": "src/entry.py",
	"compatibility_date": "2026-03-01",
	"compatibility_flags": [
		"python_workers",
		"python_dedicated_snapshot"
	],
	"vars": {
		"MESSAGE": "My env var"
	},
	"observability": {
		"enabled": true
	}
}